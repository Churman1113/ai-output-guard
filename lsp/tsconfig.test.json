{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "outDir": "out-test",
    "rootDir": ".",
    "lib": ["ES2021"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/guardClient.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "out", "out-test"]
}
