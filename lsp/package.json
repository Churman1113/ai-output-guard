{
  "name": "ai-output-guard",
  "displayName": "AI Output Guard",
  "description": "AI output safety — detects dangerous LLM output directly in your editor",
  "version": "0.1.0",
  "publisher": "ai-output-guard",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Churman1113/ai-output-guard"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Security",
    "Programming Languages"
  ],
  "keywords": [
    "ai-safety",
    "llm",
    "guardrails",
    "security",
    "linter"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentguard.validateSelection",
        "title": "AI Output Guard: Validate Selection"
      },
      {
        "command": "agentguard.validateFile",
        "title": "AI Output Guard: Validate Current File"
      },
      {
        "command": "agentguard.showAudit",
        "title": "AI Output Guard: Show Audit Log"
      },
      {
        "command": "agentguard.clearDiagnostics",
        "title": "AI Output Guard: Clear All Diagnostics"
      }
    ],
    "configuration": {
      "title": "AI Output Guard",
      "properties": {
        "agentguard.policyPath": {
          "type": "string",
          "default": "",
          "description": "Path to a YAML policy file for custom guard rules"
        },
        "agentguard.enableSemantic": {
          "type": "boolean",
          "default": true,
          "description": "Enable semantic safety checking (keyword + regex pattern matching)"
        },
        "agentguard.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Show inline diagnostics (wavy lines) for dangerous AI output"
        },
        "agentguard.guardDaemonUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8765",
          "description": "URL of the AI Output Guard daemon (start with: agentguard-daemon)"
        },
        "agentguard.dangerousIntents": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Specific dangerous intents to block (empty = block all critical/high)"
        }
      }
    },
    "keybindings": [
      {
        "command": "agentguard.validateSelection",
        "key": "ctrl+alt+g v",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "agentguard.validateSelection",
          "group": "AI Output Guard@1"
        }
      ]
    },
    "diagnosticTags": {
      "error": [" AI Output Guard "],
      "warning": [" AI Output Guard "]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run test:compile && node --test out-test/test/*.test.js",
    "test:compile": "tsc -p tsconfig.test.json",
    "test:python": "cd .. && python -m pytest tests/ -q",
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/test-electron": "^2.3.0"
  }
}
